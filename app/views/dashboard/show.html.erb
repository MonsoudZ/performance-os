<% content_for :title, "Today · PerformanceOS" %>

<main class="shell">
  <%= turbo_stream_from Current.user %>
  <%= render "shared/navigation" %>

  <section class="hero">
    <div>
      <p class="eyebrow">Today’s operating plan</p>
      <h1>Train from signal,<br>not from noise.</h1>
      <p class="lede">One daily check-in turns recovery data into a clear, auditable training decision.</p>
    </div>

    <% if @readiness_score && @decision %>
      <article class="score-card score-card--<%= @decision.output["status"] %>">
        <div class="score-ring" style="--score: <%= @readiness_score.score %>">
          <div>
            <strong><%= @readiness_score.score %></strong>
            <span>readiness</span>
          </div>
        </div>
        <div>
          <p class="eyebrow">What should I do today?</p>
          <h2><%= @decision.output["headline"] %></h2>
          <p><%= @decision.output["guidance"] %></p>
          <span class="confidence"><%= @decision.confidence %> confidence · <%= @decision.rule_key %></span>
        </div>
      </article>
    <% elsif @today_input %>
      <article class="score-card score-card--empty" aria-busy="true">
        <div class="empty-orbit"></div>
        <div>
          <p class="eyebrow">Calculating…</p>
          <h2>Generating today’s plan.</h2>
          <p>Your check-in is in. This panel updates on its own the moment the engine finishes.</p>
        </div>
      </article>
    <% else %>
      <article class="score-card score-card--empty">
        <div class="empty-orbit"></div>
        <div>
          <p class="eyebrow">No signal yet</p>
          <h2>Your plan starts with sixty seconds.</h2>
          <p>Complete today’s check-in and PerformanceOS will set the right training intensity.</p>
        </div>
      </article>
    <% end %>
  </section>

  <% if @suggested_block %>
    <section class="panel block-nudge">
      <div>
        <p class="eyebrow">Block complete</p>
        <h2>Your training block wrapped — start the next one?</h2>
        <p>We've lined up <strong><%= @suggested_block.name %></strong> (<%= @suggested_block.weeks %> weeks<% if @suggested_block.deload_week %>, deload week <%= @suggested_block.deload_week %><% end %>) to continue your progression.</p>
      </div>
      <%= link_to "Plan the next block", mesocycles_path, class: "button button--inline" %>
    </section>
  <% end %>

  <section class="panel today-workout">
    <div>
      <p class="eyebrow">Today’s workout</p>
      <% if @today_templates.any? %>
        <h2><%= @today_templates.map(&:name).to_sentence %></h2>
        <p><%= @today_templates.sum { |template| template.workout_template_exercises.size } %> planned exercises in order, with targets and previous results filled where available.</p>
      <% else %>
        <h2>No workout scheduled.</h2>
        <p>Start an ad-hoc session or schedule a workout template for <%= @user.local_date.strftime("%A") %>.</p>
      <% end %>
    </div>
    <div class="today-workout__actions">
      <% @today_templates.each do |template| %>
        <%= link_to "Start #{template.name}",
          new_workout_session_path(workout_template_id: template.id),
          class: "button button--inline" %>
      <% end %>
      <%= link_to(@today_templates.any? ? "Manage workouts" : "Create workout", workout_templates_path, class: "text-link") %>
    </div>
  </section>

  <section class="workspace">
    <article class="panel check-in">
      <div class="panel__header">
        <div>
          <p class="eyebrow">Daily input</p>
          <h2>How’s the system running?</h2>
        </div>
        <span class="step">01 / Check-in</span>
      </div>

      <% if @today_input&.checked_in? %>
        <div class="completed">
          <span class="completed__check">✓</span>
          <h3>Today’s check-in is complete.</h3>
          <p>Tomorrow’s snapshot stays independent, so your history never silently changes.</p>
          <%= link_to "Edit or review past check-ins", readiness_inputs_path, class: "text-link" %>
        </div>
      <% else %>
        <%= form_with model: @check_in, url: readiness_check_in_path, method: :post, class: "check-in__form" do |form| %>
          <% if @check_in.sleep_from_watch? %>
            <div class="synced-field">
              <span>Sleep</span>
              <strong><%= number_with_precision @check_in.sleep_hours, precision: 1, strip_insignificant_zeros: true %> h</strong>
              <small>synced from your watch</small>
            </div>
          <% else %>
            <label>
              <span>Sleep duration</span>
              <%= form.select :sleep_hours,
                sleep_hour_options(@check_in.sleep_hours),
                { selected: @check_in.sleep_hours || 7.5 } %>
            </label>
          <% end %>

          <% if @check_in.hrv_sdnn_ms.present? || @check_in.resting_hr.present? %>
            <p class="synced-note">HRV and resting heart rate synced from your watch.</p>
          <% end %>

          <%= render "rating_field", form: form, field: :sleep_quality, label: "Sleep quality", low: "Poor", high: "Excellent" %>
          <%= render "rating_field", form: form, field: :soreness, label: "Muscle soreness", low: "Fresh", high: "Very sore" %>
          <%= render "rating_field", form: form, field: :fatigue, label: "General fatigue", low: "Energized", high: "Drained" %>
          <%= render "rating_field", form: form, field: :stress, label: "Life stress", low: "Calm", high: "Overloaded" %>

          <%= form.submit "Generate today’s plan", class: "button" %>
        <% end %>
      <% end %>

      <div class="push-toggle" data-controller="push" hidden>
        <button type="button" class="text-button" data-action="push#toggle" data-push-target="button">
          Enable check-in reminders
        </button>
      </div>
    </article>

    <% if @decision %>
      <aside class="panel principles">
        <p class="eyebrow">Why this plan?</p>
        <h2>One answer, traceable inputs.</h2>
        <div class="decision-tree">
          <div class="decision-tree__parent">
            <span>Parent</span>
            <strong><%= @decision.rule_key %></strong>
            <small>Decision #<%= @decision.id %></small>
          </div>
          <% @decision_links.each do |link| %>
            <div class="decision-tree__child">
              <span><%= link.role.humanize %></span>
              <strong><%= link.child_decision.rule_key %></strong>
              <small>Decision #<%= link.child_decision.id %> · <%= link.child_decision.output["headline"] %></small>
            </div>
          <% end %>
        </div>
        <div class="principles__footer">
          <span>Composed, not recomputed</span>
          <strong><%= pluralize @decision_links.size, "child decision" %></strong>
        </div>
      </aside>
    <% else %>
      <aside class="panel principles">
        <p class="eyebrow">How the decision works</p>
        <h2>No black box.</h2>
        <ol>
          <li><span>01</span><div><strong>Read readiness</strong><p>Today’s recovery decision sets the execution constraint.</p></div></li>
          <li><span>02</span><div><strong>Read progression</strong><p>Each lift contributes its latest immutable progression state.</p></div></li>
          <li><span>03</span><div><strong>Compose</strong><p>The orchestrator writes one parent recommendation with explicit links.</p></div></li>
        </ol>
        <div class="principles__footer">
          <span>Current engine</span>
          <strong>daily_training_orchestrator.v1</strong>
        </div>
      </aside>
    <% end %>
  </section>

  <section class="panel wearable-status">
    <div>
      <p class="eyebrow">Wearable readiness</p>
      <% if @wearable_device %>
        <h2>HealthKit is connected.</h2>
        <p>
          <%= @wearable_device.name %>
          <% if @wearable_device.last_synced_at %>
            last synced <%= time_ago_in_words(@wearable_device.last_synced_at) %> ago.
          <% else %>
            is waiting for its first background sync.
          <% end %>
        </p>
      <% else %>
        <h2>Connect HealthKit in the iPhone app.</h2>
        <p>Sleep, HRV, and resting heart rate will fill the objective side of readiness. Seven prior days unlock personal HRV and heart-rate baselines.</p>
      <% end %>
    </div>
    <% if @wearable_device %>
      <%= button_to "Revoke device", wearable_device_path(@wearable_device), method: :delete, class: "nav-links__button" %>
    <% else %>
      <span class="confidence">Native pairing required · manual check-in remains available</span>
    <% end %>
    <%= link_to "Manage devices", wearable_devices_path, class: "text-link" %>
  </section>

  <% if @decision && @decision.output["lifts"].any? %>
    <section class="panel daily-plan">
      <div class="panel__header">
        <div>
          <p class="eyebrow">
            Today’s lift directives
            <% if (meso = @decision.output["mesocycle"]) %>
              · <%= meso["name"] %> — week <%= meso["week"] %>/<%= meso["total_weeks"] %><%= " · deload" if meso["deload"] %>
            <% end %>
          </p>
          <h2>Execute the plan.</h2>
          <% if (meso = @decision.output["mesocycle"]) && meso["emphasis"] %>
            <p class="evidence-note"><%= meso["emphasis"] %></p>
          <% end %>
        </div>
        <span class="step"><%= @decision.output["goal"]&.humanize || "No active goal" %></span>
      </div>
      <div class="daily-plan__grid">
        <% @decision.output["lifts"].each do |lift| %>
          <article class="lift-directive lift-directive--<%= lift["action"] %>">
            <div>
              <p class="eyebrow"><%= lift["action"].humanize %></p>
              <h3><%= lift["exercise_name"] %></h3>
            </div>
            <strong><%= lift["headline"] %></strong>
            <p><%= lift["guidance"] %></p>
            <small><%= lift["target"] %><% if lift["working_sets"] %> · <%= pluralize lift["working_sets"], "set" %> today<% end %></small>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @decision && @decision.output["nutrition"] %>
    <section class="panel nutrition-directive">
      <div>
        <p class="eyebrow">Nutrition directive</p>
        <h2><%= @decision.output.dig("nutrition", "headline") %></h2>
        <p><%= @decision.output.dig("nutrition", "guidance") %></p>
      </div>
      <% totals = @decision.output.dig("nutrition", "totals") %>
      <% targets = @decision.output.dig("nutrition", "targets") %>
      <% if totals && targets %>
        <div class="nutrition-directive__numbers">
          <div><span>Calories</span><strong><%= totals["kcal"].round %> / <%= targets["kcal"]&.round || "—" %></strong></div>
          <div><span>Protein</span><strong><%= totals["protein_g"].round %> / <%= targets["protein_g"]&.round || "—" %> g</strong></div>
        </div>
      <% end %>
      <%= link_to "Open nutrition", nutrition_path, class: "text-link" %>
    </section>
  <% end %>

  <% if (conditioning = @decision&.output&.dig("conditioning")) %>
    <section class="panel nutrition-directive conditioning-directive--<%= conditioning["focus"] %>">
      <div>
        <p class="eyebrow">Conditioning directive</p>
        <h2><%= conditioning["headline"] %></h2>
        <p><%= conditioning["guidance"] %></p>
      </div>
      <div class="nutrition-directive__numbers">
        <div><span><%= conditioning["label"].humanize %></span><strong><%= conditioning["done"] %> / <%= conditioning["target"] %></strong></div>
      </div>
      <%= link_to "Log conditioning", conditioning_sessions_path, class: "text-link" %>
    </section>
  <% end %>

  <section class="training-overview">
    <article class="panel">
      <div class="panel__header">
        <div>
          <p class="eyebrow">Current targets</p>
          <h2>Training targets</h2>
        </div>
        <%= link_to "Manage", exercise_prescriptions_path, class: "text-link" %>
      </div>

      <% if @active_prescriptions.any? %>
        <div class="compact-list">
          <% @active_prescriptions.each do |prescription| %>
            <div class="compact-list__item">
              <strong><%= prescription.exercise.name %></strong>
              <span><%= prescription.target_label %></span>
              <small>+<%= number_with_precision prescription.increment_kg, precision: 2, strip_insignificant_zeros: true %> kg</small>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <p>Progression needs a target before it can make a call.</p>
          <%= link_to "Set first training target", new_exercise_prescription_path, class: "button button--inline" %>
        </div>
      <% end %>
    </article>

    <article class="panel">
      <div class="panel__header">
        <div>
          <p class="eyebrow">Training history</p>
          <h2>Recent sessions</h2>
        </div>
        <%= link_to "Log workout", new_workout_session_path, class: "text-link" %>
      </div>

      <% if @recent_workouts.any? %>
        <div class="compact-list">
          <% @recent_workouts.each do |workout| %>
            <%= link_to workout_session_path(workout), class: "compact-list__item compact-list__item--link" do %>
              <strong><%= workout.performed_at.strftime("%b %-d · %-I:%M %p") %></strong>
              <span><%= pluralize workout.set_entries.size, "set" %></span>
              <small>View decision →</small>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <p>No sessions yet. The engine is waiting patiently, clipboard in hand.</p>
        </div>
      <% end %>
    </article>
  </section>
</main>
