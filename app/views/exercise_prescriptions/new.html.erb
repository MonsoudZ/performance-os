<main class="shell">
  <%= render "shared/navigation" %>

  <section class="page-heading">
    <div>
      <p class="eyebrow">Workout setup</p>
      <h1>Set an exercise target.</h1>
      <p>Choose the sets, rep range, effort, and weight increase you want to follow.</p>
    </div>
  </section>

  <section class="panel form-panel">
    <%= render "form", prescription: @prescription, exercises: @exercises, submit_label: "Save training target" %>
  </section>
</main>
