<main class="shell">
  <%= render "shared/navigation" %>

  <section class="page-heading">
    <div>
      <p class="eyebrow">Workout setup</p>
      <h1>Training targets.</h1>
      <p>Set the working sets, rep range, effort, and load increase for each exercise.</p>
    </div>
    <%= link_to "Add training target", new_exercise_prescription_path, class: "button button--inline" %>
  </section>

  <section class="panel">
    <% if @prescriptions.any? %>
      <div class="prescription-grid">
        <% @prescriptions.each do |prescription| %>
          <article class="prescription-card">
            <p class="eyebrow"><%= prescription.exercise.modality %></p>
            <h2><%= prescription.exercise.name %></h2>
            <strong><%= prescription.target_label %></strong>
            <dl>
              <div><dt>Increment</dt><dd><%= number_with_precision prescription.increment_kg, precision: 2, strip_insignificant_zeros: true %> kg</dd></div>
              <div><dt>Progression</dt><dd><%= prescription.progression_model_label %></dd></div>
              <div><dt>Effective</dt><dd><%= prescription.started_on.strftime("%b %-d, %Y") %></dd></div>
            </dl>
            <div class="prescription-card__actions">
              <%= link_to "Edit", edit_exercise_prescription_path(prescription), class: "text-link" %>
              <%= button_to "End", finish_exercise_prescription_path(prescription), method: :patch, class: "text-button text-button--danger" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <p>No training targets yet.</p>
      </div>
    <% end %>
  </section>
</main>
