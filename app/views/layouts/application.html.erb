<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "PerformanceOS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#244d3f">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="application-name" content="PerformanceOS">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Morph the page in place when a background recompute broadcasts a refresh,
        so live decision panels update without a jarring full reload. %>
    <%= turbo_refresh_method_tag :morph %>
    <%= turbo_refresh_scroll_tag :preserve %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <% if Rails.application.config.x.vapid[:public_key].present? %>
      <meta name="vapid-public-key" content="<%= Rails.application.config.x.vapid[:public_key] %>">
    <% end %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if notice %>
      <div class="flash flash--notice"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="flash flash--alert"><%= alert %></div>
    <% end %>
    <%= yield %>
    <%= render "shared/mobile_tab_bar" if authenticated? %>
  </body>
</html>
