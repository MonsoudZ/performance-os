<main class="shell">
  <%= turbo_stream_from Current.user %>
  <%= render "shared/navigation" %>

  <section class="page-heading">
    <div>
      <p class="eyebrow">Nutrition evidence</p>
      <h1>Fuel the objective.</h1>
      <p>Food logs snapshot their macros. Weight trends stay historically stable. Targets come from the active goal or enough evidence—not guesswork.</p>
    </div>
  </section>

  <%= render "log_workspace" %>

  <section class="nutrition-workspace nutrition-workspace--support">
    <article class="panel">
      <div class="panel__header">
        <div>
          <p class="eyebrow">Body weight</p>
          <h2>Update the trend.</h2>
        </div>
      </div>

      <%= form_with model: @body_metric, class: "stacked-form" do |form| %>
        <div class="form-grid">
          <label><span>Weight (kg)</span><%= form.number_field :weight_kg, min: 1, step: 0.01, required: true %></label>
          <label><span>Measured on</span><%= form.date_field :measured_on, required: true %></label>
        </div>
        <%= form.submit "Log weight", class: "button" %>
      <% end %>

      <% if @weight_trends.any? %>
        <div class="trend-strip">
          <% @weight_trends.reverse_each do |trend| %>
            <div>
              <span><%= trend.trend_date.strftime("%b %-d") %></span>
              <strong><%= number_with_precision trend.ewma_kg, precision: 2 %></strong>
            </div>
          <% end %>
        </div>
      <% end %>

      <p class="evidence-note">
        <% if @expenditure %>
          Adaptive expenditure: <strong><%= @expenditure.estimated_tdee.round %> kcal</strong> · <%= @expenditure.confidence %> confidence
        <% else %>
          Adaptive expenditure unlocks after 7 logged intake days and at least 7 days of weight-trend evidence.
        <% end %>
      </p>
    </article>

    <article class="panel">
      <div class="panel__header">
        <div>
          <p class="eyebrow">Food catalog</p>
          <h2>Add a staple.</h2>
        </div>
      </div>
      <%= form_with model: @food, class: "stacked-form" do |form| %>
        <div class="form-grid">
          <label><span>Name</span><%= form.text_field :name, required: true %></label>
          <label><span>Brand</span><%= form.text_field :brand %></label>
          <label><span>Serving grams</span><%= form.number_field :serving_grams, min: 1, step: 0.1, required: true %></label>
          <label><span>Calories</span><%= form.number_field :kcal, min: 0, step: 0.1, required: true %></label>
          <label><span>Protein (g)</span><%= form.number_field :protein_g, min: 0, step: 0.1, required: true %></label>
          <label><span>Carbs (g)</span><%= form.number_field :carb_g, min: 0, step: 0.1, required: true %></label>
          <label><span>Fat (g)</span><%= form.number_field :fat_g, min: 0, step: 0.1, required: true %></label>
        </div>
        <%= form.submit "Add food", class: "button" %>
      <% end %>
    </article>
  </section>
</main>
