<main class="auth-shell">
  <section class="auth-card">
    <a class="brand" href="/">
      <span class="brand__mark">P</span>
      <span>PerformanceOS</span>
    </a>
    <p class="eyebrow">Create your account</p>
    <h1>Build from signal.</h1>
    <p class="auth-card__lede">Your logs stay factual. Your recommendations stay explainable.</p>

    <% if @user.errors.any? %>
      <div class="form-errors"><%= @user.errors.full_messages.to_sentence %></div>
    <% end %>

    <%= form_with model: @user, url: registration_path, class: "stacked-form" do |form| %>
      <label>
        <span>Email</span>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email" %>
      </label>
      <label>
        <span>Password</span>
        <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72 %>
      </label>
      <label>
        <span>Confirm password</span>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72 %>
      </label>
      <label>
        <span>Display units</span>
        <%= form.select :unit_system, [["Metric", "metric"], ["Imperial", "imperial"]] %>
      </label>
      <label>
        <span>Time zone</span>
        <%= form.time_zone_select :time_zone, ActiveSupport::TimeZone.all, default: "UTC" %>
      </label>
      <%= form.submit "Create account", class: "button" %>
    <% end %>

    <p class="auth-card__footer">Already training with us? <%= link_to "Sign in", new_session_path %></p>
  </section>
</main>
